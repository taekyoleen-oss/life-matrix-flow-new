# ─────────────────────────────────────────────────────────────
# 환경변수 예시 — 실제 값은 .env (로컬) 또는 Vercel 대시보드에 설정
# .env 는 절대 커밋하지 마세요 (.gitignore 처리됨)
# ─────────────────────────────────────────────────────────────

# [개발 전용] Gemini API 키 — 개발 모드(npm run dev)에서만 폴백으로 사용됩니다.
# 프로덕션 빌드(Vercel)에는 번들에 포함되지 않으며, 일반 사용자는 앱 내
# 'AI 키 설정(🔑)'에서 본인 키를 직접 입력합니다.
# => Vercel 프로덕션에는 설정할 필요 없음.
GEMINI_API_KEY=

# [프로덕션 필요] Supabase (공유 샘플 라이브러리)
# Vercel 대시보드 > Settings > Environment Variables 에 동일 키로 설정하세요.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# (선택) 레거시 로컬 샘플 Express 서버 주소 — Supabase 사용 시 불필요
# VITE_API_URL=http://localhost:3002

# [선택] 고급기능 잠금 해제 비밀번호 (소프트 잠금)
# DSL 정의·AI 생성·AI 키 설정·PPT 보고서·코드 패널·초기화면 설정 등
# 고급기능을 사용하려면 이 비밀번호가 필요합니다. 일반 사용자는 모듈 배치·실행만 가능.
# ⚠️ 클라이언트 빌드에 포함되므로 완벽한 보안 차단이 아닌 실수 방지용입니다.
# 미설정(빈 값) 시 잠금 해제가 불가능합니다.
VITE_ADVANCED_PASSWORD=
